TELEGRAM_API_ID=123456
TELEGRAM_API_HASH=your_api_hash
TELEGRAM_SESSION_NAME=media_archiver
TELEGRAM_CHANNEL=@your_channel_or_chat_id
TELEGRAM_DOWNLOAD_DIR=downloads
DATABASE_PATH=data/archiver.db
RCLONE_REMOTE=backup:telegram-media
RCLONE_PATH_TEMPLATE={channel}/{year}/{month}/{filename}
RCLONE_EXTRA_ARGS=--transfers=2 --checkers=4
MAX_CONCURRENT_UPLOADS=2
LOG_LEVEL=INFO
HISTORY_LIMIT=0
